        <mxCell id="prom" value="📈 Prometheus Alerts&#10;Operational alerts and metrics" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fillColor=#DAE8FC;strokeColor=#6C8EBF;" vertex="1" parent="input_group">
